{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "description": "The representation of a user returned in a list",
  "type": "object",
  "properties": {
    "type_of": {
      "type": "string"
    },
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "username": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "nullable": true
    },
    "twitter_username": {
      "type": "string"
    },
    "github_username": {
      "type": "string"
    },
    "website_url": {
      "type": "string",
      "nullable": true
    },
    "location": {
      "type": "string",
      "nullable": true
    },
    "joined_at": {
      "type": "string"
    },
    "profile_image": {
      "type": "string"
    }
  }
}