{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FollowedTag",
  "description": "Representation of a followed tag",
  "type": "object",
  "properties": {
    "id": {
      "description": "Tag id",
      "type": "integer",
      "format": "int64"
    },
    "name": {
      "type": "string"
    },
    "points": {
      "type": "number",
      "format": "float"
    }
  },
  "required": [
    "id",
    "name",
    "points"
  ]
}