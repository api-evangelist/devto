{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tag",
  "description": "Representation of a tag",
  "type": "object",
  "properties": {
    "id": {
      "description": "Tag id",
      "type": "integer",
      "format": "int64"
    },
    "name": {
      "type": "string"
    },
    "bg_color_hex": {
      "type": "string",
      "nullable": true
    },
    "text_color_hex": {
      "type": "string",
      "nullable": true
    }
  }
}