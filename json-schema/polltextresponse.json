{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PollTextResponse",
  "description": "Representation of a free-text response to a text-input poll",
  "type": "object",
  "properties": {
    "type_of": {
      "type": "string",
      "enum": [
        "poll_text_response"
      ],
      "description": "Resource discriminator"
    },
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "poll_id": {
      "type": "integer",
      "format": "int64"
    },
    "user_id": {
      "type": "integer",
      "format": "int64"
    },
    "user_email": {
      "type": "string",
      "format": "email"
    },
    "text_content": {
      "type": "string"
    },
    "session_start": {
      "type": "integer",
      "format": "int32"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "type_of",
    "id",
    "poll_id",
    "user_id",
    "user_email",
    "text_content",
    "session_start",
    "created_at"
  ]
}